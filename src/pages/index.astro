---
import Base from '../layouts/Base.astro';
import WorkCard from '../components/WorkCard.astro';
import { getCollection, render } from 'astro:content';
import site from '../data/site.json';

/* ---------- PROJECTS (split Art vs Research) ---------- */
const projects = await getCollection('projects');
const projectsSorted = [...projects].sort(
  (a, b) => b.data.year - a.data.year || a.data.order - b.data.order
);
const allPubs = await getCollection('publications');

const workEntries = await Promise.all(
  projectsSorted.map(async (p) => {
    const { Content } = await render(p);
    const d = p.data;
    const relatedPubs = allPubs.filter(
      (pub) => pub.data.relatedProjects.includes(p.id) || d.publication === pub.id
    );
    const related = projectsSorted
      .filter((q) => q.id !== p.id)
      .map((q) => {
        const sharedThemes = q.data.themes.filter((t) => d.themes.includes(t));
        const sharedPeople = q.data.collaborators.filter((c) => d.collaborators.includes(c));
        return { q, score: sharedThemes.length + sharedPeople.length, shared: [...sharedThemes, ...sharedPeople] };
      })
      .filter((x) => x.score > 0)
      .sort((a, b) => b.score - a.score || b.q.data.year - a.q.data.year)
      .slice(0, 4);
    return { p, d, Content, relatedPubs, related };
  })
);
// Art list honours manual Sort order (lower = first), then most-recent year.
const artWorks = workEntries
  .filter((e) => !e.d.research)
  .sort((a, b) => a.d.order - b.d.order || b.d.year - a.d.year);
const researchWorks = workEntries.filter((e) => e.d.research).sort((a, b) => a.d.order - b.d.order);

/* Kinethic is folded inside Terra-Performing as a nested sub-entry (no image). */
const KINETHIC_ID = 'kinetic-tokenization';
const TERRA_ID = 'terra-performing';
const kinethicEntry = researchWorks.find((e) => e.p.id === KINETHIC_ID);
const researchWorksTop = researchWorks.filter((e) => e.p.id !== KINETHIC_ID);
const nestedFor = (id) => (id === TERRA_ID && kinethicEntry ? [kinethicEntry] : []);
// Don't list Kinethic under Terra-Performing's "Related works" — it's nested in.
researchWorksTop.forEach((e) => {
  if (e.p.id === TERRA_ID) e.related = e.related.filter((r) => r.q.id !== KINETHIC_ID);
});

/* ---------- RESEARCH: publications + editorial ---------- */
// Writing honours manual Sort order (lower = first), then forthcoming, then year.
const pubsSorted = [...allPubs].sort(
  (a, b) =>
    a.data.order - b.data.order ||
    (Number(b.data.forthcoming) - Number(a.data.forthcoming)) ||
    b.data.year - a.data.year
);
const pubOrder = ['book', 'chapter', 'article', 'essay', 'review', 'other'];
const pubLabels = { book: 'Book', chapter: 'Chapters', article: 'Articles', essay: 'Essays', review: 'Book reviews', other: 'Other' };
const pubGroups = pubOrder
  .map((kind) => ({ kind, items: pubsSorted.filter((p) => p.data.kind === kind) }))
  .filter((g) => g.items.length);

const svc = await getCollection('service');
const byCat = (c) => svc.filter((s) => s.data.category === c).sort((a, b) => a.data.order - b.data.order);
const editorialItems = byCat('editorial');
const leadershipItems = byCat('leadership');

/* ---------- TEACHING ---------- */
const courses = (await getCollection('teaching')).sort((a, b) => a.data.order - b.data.order);

/* ---------- PRESS (talks / interviews / media) ---------- */
const pressAll = await getCollection('press');
const byPress = (c) => pressAll
  .filter((p) => (p.data.category || 'media') === c)
  .sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0) || a.data.order - b.data.order);
const mediaItems = byPress('media');
const interviewItems = byPress('interview');
const talkItems = byPress('talk');

/* Homepage Talk card: a single talk/interview. Pinned (featured) wins;
   otherwise the most recent. */
const talkPool = [...talkItems, ...interviewItems];
const featuredTalkEntry =
  (site.banners?.talkCard && talkPool.find((t) => t.id === site.banners.talkCard)) ??
  talkPool.find((t) => t.data.featured) ??
  talkPool[0];
const talkText = featuredTalkEntry
  ? (featuredTalkEntry.data.title
      ? `${featuredTalkEntry.data.title} — ${featuredTalkEntry.data.outlet}`
      : featuredTalkEntry.data.outlet)
  : null;

/* ---------- CROSS-LINK TITLE LOOKUPS ---------- */
const projTitle = Object.fromEntries(projects.map((p) => [p.id, p.data.title]));
const pubTitle = Object.fromEntries(allPubs.map((p) => [p.id, p.data.title]));
const svcTitle = Object.fromEntries(svc.map((s) => [s.id, s.data.title]));
const xlinks = (s) => [
  ...s.data.relatedProjects.map((id) => ({ href: `#${id}`, label: projTitle[id] || id })),
  ...s.data.relatedPubs.map((id) => ({ href: `#${id}`, label: pubTitle[id] || id })),
];

/* ---------- SURFACE FEATURES ---------- */
const books = allPubs
  .filter((p) => p.data.kind === 'book')
  .sort((a, b) => (Number(b.data.forthcoming) - Number(a.data.forthcoming)) || b.data.year - a.data.year);
const book = books[0];

/* ---------- HOMEPAGE BANNERS (chosen in CMS → Site settings → Homepage banners) ----------
   For each card: an explicit pick in Site settings wins; otherwise the old
   per-item checkbox; otherwise the most recent. */
const banners = site.banners || {};
// Latest work card.
const latest = (
  (banners.latestWork && artWorks.find((e) => e.p.id === banners.latestWork)) ??
  artWorks.find((e) => e.d.featured) ??
  artWorks[0]
)?.p;
// New publication card (books excluded).
const nonBookPubs = pubsSorted.filter((p) => p.data.kind !== 'book');
const latestPub =
  (banners.newPublication && nonBookPubs.find((p) => p.id === banners.newPublication)) ??
  nonBookPubs.find((p) => p.data.featured) ??
  nonBookPubs[0];
// Press banner outlets (media items).
const pressPicks = (banners.pressBanner || [])
  .map((id) => mediaItems.find((p) => p.id === id))
  .filter(Boolean);
const marqueePress = mediaItems.filter((p) => p.data.marquee);
const featuredPress = pressPicks.length
  ? pressPicks
  : (marqueePress.length ? marqueePress : mediaItems.slice(0, 4));

const sections = [
  { id: 'art', label: 'Art' },
  { id: 'research', label: 'Research' },
  { id: 'teaching', label: 'Teaching' },
  { id: 'press', label: 'Press' },
];
---
<Base>
  <header class="topbar mono" data-topbar>
    <a class="tb-name" href="#top">{site.name}</a>
    <nav class="tb-links" aria-label="Sections">
      {sections.map((s) => <a href={`#${s.id}`} data-dlink={s.id}>{s.label}</a>)}
    </nav>
    <div class="tb-right">
      <button type="button" class="tb-collapse" data-collapse-all>Collapse all</button>
      <button type="button" class="tb-menu" data-menu-toggle aria-label="Open sections menu" aria-expanded="false">Menu</button>
    </div>
    <div class="tb-drawer" data-drawer hidden>
      {sections.map((s) => <a href={`#${s.id}`} data-drawer-link>{s.label}</a>)}
      <button type="button" class="tb-collapse" data-collapse-all>Collapse all</button>
    </div>
  </header>

  <!-- 0 · SURFACE -->
  <section id="top" class="surface">
    <div class="wrap surface-grid">
      <div class="surface-header">
        <p class="depth mono">0 m · surface</p>
        <h1>{site.name}</h1>
        {site.homeBioShort ? (
          <div class="biofold" data-biofold>
            <p class="homebio bio-short" data-bio-short>{site.homeBioShort}
              <button type="button" class="bio-toggle mono" data-bio-more aria-expanded="false">Read more +</button>
            </p>
            <p class="homebio bio-full" data-bio-full hidden>{site.bio}
              <button type="button" class="bio-toggle mono" data-bio-less aria-expanded="true">Read less −</button>
            </p>
          </div>
        ) : (
          <p class="homebio">{site.bio}</p>
        )}
        {site.social && (
          <p class="socials mono">
            {site.social.linkedin && <a href={site.social.linkedin}>LinkedIn</a>}
            {site.social.instagram && <> · <a href={site.social.instagram}>Instagram</a></>}
            {site.social.scholar && <> · <a href={site.social.scholar}>Google Scholar</a></>}
            {site.social.orcid && <> · <a href={site.social.orcid}>ORCID</a></>}
          </p>
        )}
      </div>

      {book && (
        <a class="book-feature" href="#research">
          {book.data.cover && <img src={book.data.cover} alt={book.data.title} loading="lazy" />}
          <span class="book-tag mono">{book.data.forthcoming ? 'Forthcoming book' : 'New book'}</span>
          <span class="book-title">{book.data.title}</span>
          {book.data.summary && <span class="book-sum muted">{book.data.summary}</span>}
        </a>
      )}

      <div class="surface-cards">
        <div class="current">
          {talkText && (
            <a class="now talk-card" href={featuredTalkEntry?.data.url || '#press'}>
              <span class="now-label mono">Talk</span>
              <span class="now-text">{talkText}</span>
            </a>
          )}
          {latest && (
            <a class="latest" href={`#${latest.id}`}>
              <span class="now-label mono">Latest work</span>
              <span class="now-text">{latest.data.title} <span class="muted">({latest.data.year})</span></span>
            </a>
          )}
          {latestPub && (
            <a class="pub-card" href={`#${latestPub.id}`}>
              <span class="now-label mono">New publication</span>
              <span class="now-text">{latestPub.data.title}{latestPub.data.venue && <span class="muted"> · {latestPub.data.venue}</span>}</span>
            </a>
          )}
        </div>

        {featuredPress.length > 0 && (
          <div class="featured-in">
            <span class="fi-label mono">Press</span>
            <span class="fi-outlets">
              {featuredPress.map((p, i) => (
                <>
                  {i > 0 && <span class="fi-dot">·</span>}
                  {p.data.url ? <a href={p.data.url}>{p.data.outlet}</a> : <span>{p.data.outlet}</span>}
                </>
              ))}
            </span>
          </div>
        )}

        <p class="scroll-hint mono">scroll to descend ↓</p>
      </div>
    </div>
  </section>

  <div class="corpus">

    <!-- −1 · ART -->
    <section id="art" class="sec">
      <header class="sec-head wrap">
        <p class="depth mono">−1 · art</p>
        <h2 class="sec-title">Art</h2>
      </header>
      <div class="wrap works">
        {artWorks.map((e) => <WorkCard entry={e} />)}
      </div>
      <p class="enter mono wrap"><a href="#top">↑ Return to the surface</a></p>
    </section>

    <!-- −2 · RESEARCH -->
    <section id="research" class="sec">
      <header class="sec-head wrap">
        <p class="depth mono">−2 · research</p>
        <h2 class="sec-title">Research</h2>
      </header>
      <div class="wrap narrow">
        {pubGroups.map((g) => (
          <section class="subsec">
            <h3 class="kind">{pubLabels[g.kind]}</h3>
            <ul class="pubs">
              {g.items.map((p) => (
                <li id={p.id} class="pub">
                  <div class="pub-title">
                    {p.data.url ? <a href={p.data.url}>{p.data.title}</a> : p.data.title}
                    {p.data.forthcoming && <span class="badge mono">forthcoming</span>}
                  </div>
                  <div class="pub-meta mono muted">
                    {p.data.authors.join(', ')}
                    {p.data.venue && <> · {p.data.venue}</>}
                    {!p.data.forthcoming && <> · {p.data.year}</>}
                    {p.data.doi && <> · doi:{p.data.doi}</>}
                  </div>
                  {p.data.summary && <p class="pub-summary muted">{p.data.summary}</p>}
                  {(p.data.pdf || p.data.relatedProjects.length > 0) && (
                    <p class="pub-actions mono">
                      {p.data.pdf && <a class="pdf-link" href={p.data.pdf}>PDF ↓</a>}
                      {p.data.relatedProjects.length > 0 && (
                        <span class="pub-rel">→ {p.data.relatedProjects.map((rp, i) => (
                          <>{i > 0 && ', '}<a href={`#${rp}`}>{projTitle[rp] || rp.replace(/-/g, ' ')}</a></>
                        ))}</span>
                      )}
                    </p>
                  )}
                </li>
              ))}
            </ul>
          </section>
        ))}

        {researchWorksTop.length > 0 && (
          <section class="subsec">
            <h3 class="kind">Research projects</h3>
            <div class="works">
              {researchWorksTop.map((e) => <WorkCard entry={e} nested={nestedFor(e.p.id)} />)}
            </div>
          </section>
        )}

        {leadershipItems.length > 0 && (
          <section class="subsec">
            <h3 class="kind">Research leadership</h3>
            <ul class="rows">
              {leadershipItems.map((s) => (
                <li class="row" id={s.id}>
                  <span class="row-title">{s.data.url ? <a href={s.data.url}>{s.data.title}</a> : s.data.title}</span>
                  <span class="row-meta mono muted">{s.data.org}{s.data.org && s.data.years && ' · '}{s.data.years}</span>
                  {s.data.summary && <p class="row-sum muted">{s.data.summary}</p>}
                  {xlinks(s).length > 0 && <p class="row-links mono">{xlinks(s).map((x) => <a class="xlink" href={x.href}>→ {x.label}</a>)}</p>}
                </li>
              ))}
            </ul>
          </section>
        )}

        {editorialItems.length > 0 && (
          <section class="subsec">
            <h3 class="kind">Editorial</h3>
            <ul class="rows">
              {editorialItems.map((s) => (
                <li class="row" id={s.id}>
                  <span class="row-title">{s.data.url ? <a href={s.data.url}>{s.data.title}</a> : s.data.title}</span>
                  <span class="row-meta mono muted">{s.data.org}{s.data.org && s.data.years && ' · '}{s.data.years}</span>
                  {s.data.summary && <p class="row-sum muted">{s.data.summary}</p>}
                </li>
              ))}
            </ul>
          </section>
        )}

        <p class="enter mono"><a href="#top">↑ Return to the surface</a></p>
      </div>
    </section>

    <!-- −3 · TEACHING -->
    <section id="teaching" class="sec">
      <header class="sec-head wrap">
        <p class="depth mono">−3 · teaching</p>
        <h2 class="sec-title">Teaching</h2>
      </header>
      <div class="wrap narrow">
        <p class="muted lead">Research-led courses and seminars, several developed with biennials, museums, and partner institutions.</p>
        <ul class="rows">
          {courses.map((c) => (
            <li class="row">
              <span class="row-title big-title">{c.data.title}</span>
              <span class="row-meta mono muted">
                {c.data.institution}
                {c.data.level && <> · {c.data.level}</>}
                {c.data.credits && <> · {c.data.credits}</>}
                {c.data.years && <> · {c.data.years}</>}
                {c.data.role && <> · {c.data.role}</>}
              </span>
              {c.data.summary && <p class="row-sum muted">{c.data.summary}</p>}
              {c.data.partners.length > 0 && <p class="row-sum mono muted">with {c.data.partners.join(', ')}</p>}
              {(c.data.links.length > 0 || c.data.related.length > 0) && (
                <p class="row-links mono">
                  {c.data.links.map((l) => <a class="xlink" href={l.url}>↗ {l.label}</a>)}
                  {c.data.related.map((rid) => <a class="xlink" href={`#${rid}`}>→ {svcTitle[rid] || pubTitle[rid] || rid}</a>)}
                </p>
              )}
            </li>
          ))}
        </ul>
        <p class="enter mono"><a href="#top">↑ Return to the surface</a></p>
      </div>
    </section>

    <!-- −4 · PRESS -->
    <section id="press" class="sec">
      <header class="sec-head wrap">
        <p class="depth mono">−4 · press</p>
        <h2 class="sec-title">Press, Interviews &amp; Talks</h2>
      </header>
      <div class="wrap narrow">
        {mediaItems.length > 0 && (
          <section class="subsec">
            <h3 class="kind">Press</h3>
            <p class="media-para">
              {mediaItems.map((p, i) => (
                <>
                  {i > 0 && <span class="mp-sep"> · </span>}
                  {p.data.url ? <a href={p.data.url}>{p.data.outlet}</a> : <span>{p.data.outlet}</span>}
                  {(p.data.date || p.data.year) && <span class="muted"> ({p.data.date || p.data.year})</span>}
                </>
              ))}
            </p>
          </section>
        )}
        {interviewItems.length > 0 && (
          <section class="subsec">
            <h3 class="kind">Interviews</h3>
            <ul class="entries">
              {interviewItems.map((p) => (
                <li class="entry">
                  <a class="entry-title" href={p.data.url || '#'}>{p.data.title || p.data.outlet}</a>
                  <span class="entry-meta mono muted">{p.data.outlet}{(p.data.date || p.data.year) ? ` · ${p.data.date || p.data.year}` : ''}</span>
                </li>
              ))}
            </ul>
          </section>
        )}
        {talkItems.length > 0 && (
          <section class="subsec">
            <h3 class="kind">Lectures &amp; Talks</h3>
            <ul class="entries">
              {talkItems.map((p) => (
                <li class="entry">
                  <a class="entry-title" href={p.data.url || '#'}>{p.data.title || p.data.outlet}</a>
                  <span class="entry-meta mono muted">{p.data.outlet}{(p.data.date || p.data.year) ? ` · ${p.data.date || p.data.year}` : ''}</span>
                </li>
              ))}
            </ul>
          </section>
        )}
        <p class="enter mono"><a href="#top">↑ Return to the surface</a></p>
      </div>
    </section>

  </div>

</Base>

<script>
  function openTarget(id: string) {
    if (!id) return;
    const el = document.getElementById(id);
    if (!el) return;
    const det = (el.tagName.toLowerCase() === 'details' ? el : el.querySelector('details')) as HTMLDetailsElement | null;
    if (det) det.open = true;
    el.scrollIntoView({ block: 'start' });
  }
  window.addEventListener('hashchange', () => openTarget(decodeURIComponent(location.hash.slice(1))));
  window.addEventListener('load', () => { if (location.hash) setTimeout(() => openTarget(decodeURIComponent(location.hash.slice(1))), 60); });
  document.addEventListener('click', (e) => {
    const a = (e.target as HTMLElement).closest('a[href^="#"]') as HTMLAnchorElement | null;
    if (!a) return;
    const id = decodeURIComponent(a.getAttribute('href')!.slice(1));
    const el = id && document.getElementById(id);
    if (el) { const det = el.querySelector('details') as HTMLDetailsElement | null; if (det) det.open = true; }
  });

  const dlinks = [...document.querySelectorAll('[data-dlink]')] as HTMLElement[];
  const spy = new IntersectionObserver((entries) => {
    entries.forEach((en) => {
      if (en.isIntersecting) {
        const id = (en.target as HTMLElement).id;
        dlinks.forEach((l) => l.classList.toggle('active', l.getAttribute('data-dlink') === id));
      }
    });
  }, { rootMargin: '-45% 0px -50% 0px' });
  document.querySelectorAll('.corpus .sec').forEach((s) => spy.observe(s));

  const drawer = document.querySelector('[data-drawer]') as HTMLElement | null;
  const toggle = document.querySelector('[data-menu-toggle]');
  const setDrawer = (open: boolean) => {
    if (!drawer) return;
    drawer.hidden = !open;
    toggle?.setAttribute('aria-expanded', String(open));
  };
  toggle?.addEventListener('click', () => setDrawer(drawer?.hidden ?? true));
  document.querySelectorAll('[data-drawer-link]').forEach((l) => l.addEventListener('click', () => setDrawer(false)));
  document.querySelectorAll('[data-collapse-all]').forEach((b) =>
    b.addEventListener('click', () => {
      document.querySelectorAll('details[open]').forEach((d) => ((d as HTMLDetailsElement).open = false));
      setDrawer(false);
    })
  );

  const fold = document.querySelector('[data-biofold]');
  if (fold) {
    const short = fold.querySelector('[data-bio-short]') as HTMLElement | null;
    const full = fold.querySelector('[data-bio-full]') as HTMLElement | null;
    const more = fold.querySelector('[data-bio-more]');
    const less = fold.querySelector('[data-bio-less]');
    const show = (expanded: boolean) => {
      if (!short || !full) return;
      short.hidden = expanded;
      full.hidden = !expanded;
    };
    more?.addEventListener('click', () => show(true));
    less?.addEventListener('click', () => show(false));
  }
</script>

<style>
  /* ---------- Persistent menu bar ---------- */
  .topbar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 80;
    display: flex; align-items: center; gap: 1.2rem; padding: .55rem 1.3rem;
    background: color-mix(in srgb, #14110d 72%, transparent);
    backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,.09);
    font-size: .82rem;
  }
  .tb-name { color: var(--surface); font-weight: 600; border: none; white-space: nowrap; letter-spacing: .01em; }
  .tb-name:hover { color: var(--accent); }
  .tb-links { display: flex; gap: 1.2rem; flex: 1; }
  .tb-links a { color: rgba(236,232,224,.72); border: none; }
  .tb-links a:hover { color: var(--surface); }
  .tb-links a.active { color: var(--accent); }
  .tb-right { display: flex; align-items: center; gap: .7rem; margin-left: auto; }
  .tb-collapse, .tb-menu {
    background: none; border: 1px solid rgba(255,255,255,.2); color: rgba(236,232,224,.8);
    border-radius: 999px; padding: .3rem .75rem; cursor: pointer;
    font-family: var(--font-mono); font-size: .72rem; transition: border-color .2s, color .2s;
  }
  .tb-collapse:hover, .tb-menu:hover { border-color: var(--accent); color: var(--accent); }
  .tb-menu { display: none; }
  .tb-drawer { display: none; }
  @media (max-width: 720px) {
    .tb-links { display: none; }
    .tb-right .tb-collapse { display: none; }
    .tb-menu { display: inline-block; }
    .tb-drawer[hidden] { display: none; }
    .tb-drawer {
      position: absolute; top: 100%; left: 0; right: 0;
      display: flex; flex-direction: column; gap: .2rem; padding: .6rem 1.3rem 1rem;
      background: color-mix(in srgb, #14110d 94%, transparent); backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,.1);
    }
    .tb-drawer a { color: var(--surface); border: none; font-size: 1.05rem; padding: .5rem 0; border-bottom: 1px solid rgba(255,255,255,.07); }
    .tb-drawer a:hover { color: var(--accent); }
    .tb-drawer .tb-collapse { align-self: flex-start; margin-top: .6rem; }
  }

  .depth { font-size: .72rem; letter-spacing: .15em; text-transform: uppercase; color: var(--muted); margin: 0 0 1rem; }

  /* ---------- 0 · Surface ---------- */
  .surface { background: linear-gradient(180deg, var(--surface) 0%, var(--layer-1) 100%); color: #1a1712; min-height: 100svh; display: flex; align-items: center; padding: 5rem 0 4rem; }
  .surface .depth { color: rgba(20,18,13,.5); }
  .surface h1 { font-size: clamp(2.3rem, 7vw, 4.4rem); margin: 0; line-height: 1; letter-spacing: -.02em; }
