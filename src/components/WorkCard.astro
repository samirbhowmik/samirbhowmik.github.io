---
/**
 * WorkCard — one expandable project card. Used in both Art (−1) and the
 * Research projects group (−2). Media (video / gallery carousel / cover)
 * sits under the title, always visible; only the deeper text is behind Unfold.
 */
import Gallery from './Gallery.astro';
import VideoEmbed from './VideoEmbed.astro';

const { entry, nested = [] } = Astro.props;
const { p, d, Content, relatedPubs, related } = entry;
---
<article class="work" id={p.id}>
  <div class="work-head">
    <h3 class="work-title">{d.title} <span class="wy muted">({d.year})</span></h3>
    <p class="work-meta mono muted">
      {d.type.join(' · ')}
      {d.venue && <> · {d.venueUrl ? <a href={d.venueUrl}>{d.venue}</a> : d.venue}</>}
      {d.collaborators.length > 0 && <> · with {d.collaborators.join(', ')}</>}
    </p>
  </div>

  {/* Media under the title — always visible, never behind Unfold. */}
  {d.video ? (
    <VideoEmbed url={d.video} title={d.title} />
  ) : d.gallery && d.gallery.length > 0 ? (
    <Gallery images={d.gallery} />
  ) : d.cover ? (
    <Gallery images={[{ src: d.cover, alt: d.title }]} />
  ) : (
    <div class="media-empty mono" aria-hidden="true"><span>image / video</span></div>
  )}

  <p class="work-summary">{d.summary}</p>

  <details class="unfold">
    <summary class="unfold-btn">
      <span class="unfold-label mono">Unfold</span>
      <span class="unfold-line" aria-hidden="true"></span>
    </summary>
    <div class="unfold-body">
      <div class="prose"><Content /></div>

      {nested.length > 0 && (
        <div class="nested">
          <p class="rel-head mono">Within this project</p>
          {nested.map((c) => (
            <div class="subwork" id={c.p.id}>
              <h4 class="subwork-title">{c.d.title} <span class="muted">({c.d.year})</span></h4>
              {c.d.collaborators.length > 0 && (
                <p class="subwork-meta mono muted">with {c.d.collaborators.join(', ')}</p>
              )}
              <p class="subwork-sum">{c.d.summary}</p>
              {(c.d.liveUrl || c.d.repoUrl) && (
                <p class="work-links mono">
                  {c.d.liveUrl && <a class="plink" href={c.d.liveUrl}>↗ Live project</a>}
                  {c.d.repoUrl && <a class="plink" href={c.d.repoUrl}>↗ Source code</a>}
                </p>
              )}
            </div>
          ))}
        </div>
      )}

      {(d.liveUrl || d.repoUrl) && (
        <p class="work-links mono">
          {d.liveUrl && <a class="plink" href={d.liveUrl}>↗ Live project</a>}
          {d.repoUrl && <a class="plink" href={d.repoUrl}>↗ Source code</a>}
        </p>
      )}

      {d.themes.length > 0 && (
        <p class="themes">{d.themes.map((t) => <span class="tag">{t}</span>)}</p>
      )}

      {relatedPubs.length > 0 && (
        <div class="related">
          <p class="rel-head mono">Related writing</p>
          <ul class="rel">
            {relatedPubs.map((pub) => (
              <li><a href={`#${pub.id}`}>{pub.data.title}</a>
                <span class="mono muted"> — {pub.data.kind}{pub.data.forthcoming ? ', forthcoming' : `, ${pub.data.year}`}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      {related.length > 0 && (
        <div class="related">
          <p class="rel-head mono">Related works</p>
          <ul class="rel">
            {related.map(({ q, shared }) => (
              <li>
                <a href={`#${q.id}`}>{q.data.title}</a>
                <span class="mono muted"> ({q.data.year})</span>
                <span class="shared mono muted"> · shares {shared.join(', ')}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </details>
</article>

<style>
  .work { max-width: 820px; }
  .work-title { font-size: 1.5rem; margin: 0; line-height: 1.15; }
  .wy { font-weight: 400; }
  .work-meta { font-size: .78rem; margin: .35rem 0 0; }
  .work-summary { font-size: 1.05rem; line-height: 1.5; margin: 1rem 0 0; max-width: 60ch; }
  .media-empty {
    margin-top: 1rem; aspect-ratio: 16/9; border: 1px dashed rgba(255,255,255,.16);
    border-radius: 5px; display: grid; place-items: center; color: var(--muted);
    font-size: .8rem; letter-spacing: .1em; text-transform: uppercase;
    background: rgba(255,255,255,.02);
  }
  .unfold { margin-top: 1.1rem; }
  .unfold-btn { display: flex; align-items: center; gap: .9rem; cursor: pointer; list-style: none; width: 100%; user-select: none; }
  .unfold-btn::-webkit-details-marker { display: none; }
  .unfold-label {
    font-size: .72rem; text-transform: uppercase; letter-spacing: .16em; color: var(--accent);
    border: 1px solid var(--accent); border-radius: 999px; padding: .25rem .8rem;
    transition: background .2s, color .2s; white-space: nowrap;
  }
  .unfold-btn:hover .unfold-label { background: var(--accent); color: #1a1712; }
  .unfold-line { flex: 1; height: 1px; background: rgba(255,255,255,.12); }
  .unfold[open] .unfold-label::after { content: ' ↑'; }
  .unfold:not([open]) .unfold-label::after { content: ' ↓'; }
  .unfold-body { padding-top: 1.2rem; animation: unfoldin .35s ease; }
  @keyframes unfoldin { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: none; } }
  .prose { max-width: 68ch; }
  .prose :global(p) { margin: 0 0 1rem; }
  .prose :global(a) { border-color: rgba(216,166,87,.5); }
  .work-links { display: flex; flex-wrap: wrap; gap: .6rem; margin: 1.2rem 0 0; }
  .plink { border: 1px solid var(--line); border-radius: 6px; padding: .5rem .9rem; font-size: .85rem; font-weight: 600; transition: border-color .2s, color .2s; }
  .plink:hover { border-color: var(--accent); color: var(--accent); }
  .themes { display: flex; flex-wrap: wrap; gap: .4rem; margin: 1.4rem 0 0; }
  .nested { margin-top: 1.6rem; padding-left: 1rem; border-left: 2px solid rgba(216,166,87,.35); }
  .nested .rel-head { margin-bottom: .7rem; }
  .subwork { padding: .3rem 0 0; scroll-margin-top: 4.6rem; }
  .subwork-title { font-size: 1.15rem; margin: 0; line-height: 1.2; }
  .subwork-meta { font-size: .74rem; margin: .25rem 0 0; }
  .subwork-sum { font-size: .98rem; line-height: 1.5; margin: .5rem 0 0; max-width: 60ch; }
  .related { margin-top: 1.4rem; }
  .rel-head { font-size: .68rem; text-transform: uppercase; letter-spacing: .14em; color: var(--muted); margin: 0 0 .4rem; }
  .rel { list-style: none; padding: 0; margin: 0; }
  .rel li { padding: .4rem 0; border-bottom: 1px solid var(--line); font-size: .95rem; }
  .shared { font-size: .72rem; }
</style>
